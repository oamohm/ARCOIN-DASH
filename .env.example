# ARCOIN — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── ARC NETWORK ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002

# ── CIRCLE PROGRAMMABLE WALLETS (User-Controlled) ────────────────────────────
# All three keys are from: https://console.circle.com → Programmable Wallets
#
# SERVER-SIDE (API routes only — never use NEXT_PUBLIC_ prefix)
CIRCLE_API_KEY=

# CLIENT-SIDE (browser SDK — MUST use NEXT_PUBLIC_ so Next.js exposes them)
# Your KIT_KEY goes here:
NEXT_PUBLIC_CIRCLE_APP_ID=
# Your TEST_CLIENT_KEY goes here:
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=

# Circle environment: sandbox (testnet) | production (mainnet)
CIRCLE_ENV=sandbox

# ── ANTHROPIC (AI Help — Phase 5) ─────────────────────────────────────────────
# Get from: https://console.anthropic.com
# SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── CONTRACTS (auto-filled by post-deploy-patch.ts after deployment) ──────────
# NEXT_PUBLIC_PAYMENT_ROUTER=0x...
# NEXT_PUBLIC_REGISTRY=0x...
# NEXT_PUBLIC_TREASURY=0x...

# ── HARDHAT (contract deployment only — never needed for frontend) ────────────
# DEPLOYER_PRIVATE_KEY=0x...
# TREASURY_MULTISIG=0x...
# DEV_FUND=0x...
# LIQUIDITY_RESERVE=0x...
# COMMUNITY_MULTISIG=0x...
