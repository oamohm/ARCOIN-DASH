# ARCOIN — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ── ARC NETWORK ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002

# ── CIRCLE DEVELOPER-CONTROLLED WALLETS ──────────────────────────────────────
# Get from: https://console.circle.com → Developer → API Keys
# SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix for these
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CIRCLE_ENTITY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Circle Wallet Set ID — created once via API, reused for all users
# Run: node scripts/create-wallet-set.mjs  (see DEPLOY.md Step 2)
CIRCLE_WALLET_SET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Circle environment: sandbox | production
CIRCLE_ENV=sandbox

# ── ANTHROPIC (AI Help — Phase 5) ─────────────────────────────────────────────
# Get from: https://console.anthropic.com
# SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── CONTRACTS (filled automatically by post-deploy-patch.ts) ─────────────────
# NEXT_PUBLIC_PAYMENT_ROUTER=0x...
# NEXT_PUBLIC_REGISTRY=0x...
# NEXT_PUBLIC_TREASURY=0x...

# ── PHASE 3 UPGRADE HOOKS (leave blank for now) ───────────────────────────────
# NEXT_PUBLIC_CHAINALYSIS_KEY=
# NEXT_PUBLIC_TRM_KEY=
